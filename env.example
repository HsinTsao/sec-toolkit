# Security Toolkit 环境变量配置
# 复制此文件为 .env 并按实际环境修改。
#
# 此文件会被后端直接读取。前端 Docker 生产部署不需要 VITE_* 变量。

# ==================== 基础配置 ====================

# 数据库 URL（可选）
# 默认会自动使用本地 ./data/toolkit.db 或 Docker 中的 /app/data/toolkit.db。
# 如果你显式指定路径，请确保和部署挂载目录一致。
# DATABASE_URL=sqlite+aiosqlite:////app/data/toolkit.db

# Docker 部署时可选覆盖宿主机挂载目录：
# APP_DATA_DIR=/opt/sec-toolkit/data
# APP_BACKEND_LOG_DIR=/opt/sec-toolkit/logs/backend
# APP_NGINX_LOG_DIR=/opt/sec-toolkit/logs/nginx
# APP_POC_FILE_DIR=/opt/sec-toolkit/data/poc-files

# 如果服务器无法访问 Docker Hub，可改成你能访问的镜像地址，例如私有仓库或镜像代理：
# PYTHON_BASE_IMAGE=python:3.11-slim
# NODE_BASE_IMAGE=node:20-alpine
# NGINX_BASE_IMAGE=nginx:alpine

# JWT 密钥（生产环境必须替换为随机长密钥）
JWT_SECRET_KEY=change-this-to-a-long-random-secret

# 生产环境保持 false
DEBUG=false

# CORS 配置（JSON 数组格式）
# 生产环境请替换为你的真实域名，例如:
# CORS_ORIGINS=["https://toolkit.example.com"]
CORS_ORIGINS=["http://localhost","https://localhost"]

# 应用对外基础地址（可选）
# 用于生成回调链接等完整 URL，例如:
# CALLBACK_BASE_URL=https://toolkit.example.com
CALLBACK_BASE_URL=

# ==================== HTTPS 配置（仅后端感知） ====================

SSL_ENABLED=false
SSL_KEYFILE=
SSL_CERTFILE=

# ==================== 默认 LLM 配置（可选） ====================

DEFAULT_LLM_PROVIDER=
DEFAULT_LLM_API_KEY=
DEFAULT_LLM_BASE_URL=
DEFAULT_LLM_MODEL=

INTENT_LLM_MODEL=
SUMMARY_LLM_MODEL=
DUAL_LLM_ENABLED=true
